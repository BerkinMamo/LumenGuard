{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "backend-cluster",
        "Match": {
          "Path": "/connect/{**catch-all}"
        }
      },
      "system-route": {
        "ClusterId": "backend-cluster",
        "Match": {
          "Path": "/api/system/{**catch-all}"
        }
      },
      "vault-route": {
        "ClusterId": "backend-cluster",
        "Match": {
          "Path": "/api/vault/{**catch-all}" 
        }
      }
    },
    "Clusters": {
      "backend-cluster": {
        "Destinations": {
          "primary": {
            "Address": "https://localhost:7044" 
          }
        }
      }
    }
  }
}